# Copy to .env and fill in. .env is gitignored.

# Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_key_here

# Qdrant server URL. Leave unset to use the embedded on-disk fallback store.
# With `docker compose up -d` running, point the app at the container:
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=            # only needed for a secured Qdrant deployment

# LangSmith tracing (optional). Off unless LANGSMITH_TRACING=true AND a key are set;
# LangGraph then emits traces natively - no code change. Traces are tagged with the
# per-query request_id that also appears in the app's structured logs.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_key_here
# LANGSMITH_PROJECT=colpali-vision-rag
