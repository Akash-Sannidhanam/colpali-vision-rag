# Copy to .env and fill in. .env is gitignored.

# Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_key_here

# Qdrant server URL. Leave unset to use the embedded on-disk fallback store.
# With `docker compose up -d` running, point the app at the container:
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=            # only needed for a secured Qdrant deployment
